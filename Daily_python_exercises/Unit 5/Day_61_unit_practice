#generators
def even(max):
    for i in range(1,max+1):
        if i % 2 == 0:
            yield i
        else:
            continue

even_nums = even(int(input("What number would you like to be the max. of even nums\n")))
print(list(i for i in even_nums))


#yield from
fruits = ["apple", "pear"]
tools = ["hammer", "drill"]
def combination(list1, list2):
    yield from list1+list2

next_item = combination(fruits, tools)
print(list(next_item))


